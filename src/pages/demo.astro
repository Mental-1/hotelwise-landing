---
import Layout from '../layouts/Layout.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Book a Demo | HotelWise">
  <!-- Minimal header with just logo -->
  <header class="minimal-header">
    <div class="container header-inner">
      <a href="/" class="logo">
        <span class="logo-icon">H</span>
        <span class="logo-text">HotelWise</span>
      </a>
    </div>
  </header>

  <main class="demo-page">
    <!-- Form Area -->
    <div class="form-area">
      <div class="form-wrapper">
        <form id="demo-form" class="multi-step-form">
          <div class="step-grid">
            <!-- Static Left Side -->
            <div class="step-left">
              <h1>Get a demo &rarr;</h1>
              <p class="step-subtitle" id="step-subtitle">Which best describes your business?</p>
            </div>

            <!-- Animated Right Side -->
            <div class="step-right">
              <div class="step-panels">
                <!-- Step 1: Business Type -->
                <div class="step-panel active" data-step="1">
                  <div class="option-list">
                    <label class="option-item">
                      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M18 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V4a2 2 0 0 0-2-2Z"/><path d="m9 16 .348-.24c1.465-1.013 3.84-1.013 5.304 0L15 16"/><circle cx="12" cy="11" r="2"/></svg>
                      <span class="option-text">Hotel</span>
                      <input type="radio" name="business_type" value="hotel" />
                      <span class="radio-circle"></span>
                    </label>
                    <label class="option-item">
                      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M2 20v-8a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v8"/><path d="M4 10V6a2 2 0 0 1 2-2h12a2 2 0 0 1 2 2v4"/><path d="M12 4v6"/><path d="M2 18h20"/></svg>
                      <span class="option-text">Resort / Lodge</span>
                      <input type="radio" name="business_type" value="resort" />
                      <span class="radio-circle"></span>
                    </label>
                    <label class="option-item">
                      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 2v7c0 1.1.9 2 2 2h4a2 2 0 0 0 2-2V2"/><path d="M7 2v20"/><path d="M21 15V2v0a5 5 0 0 0-5 5v6c0 1.1.9 2 2 2h3Zm0 0v7"/></svg>
                      <span class="option-text">Restaurant / Bar / Club</span>
                      <input type="radio" name="business_type" value="restaurant" />
                      <span class="radio-circle"></span>
                    </label>
                    <label class="option-item">
                      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9,22 9,12 15,12 15,22"/></svg>
                      <span class="option-text">Vacation Rental</span>
                      <input type="radio" name="business_type" value="vacation_rental" />
                      <span class="radio-circle"></span>
                    </label>
                    <label class="option-item">
                      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M16 20V4a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/><rect width="20" height="14" x="2" y="6" rx="2"/></svg>
                      <span class="option-text">Consultant / Partner</span>
                      <input type="radio" name="business_type" value="consultant" />
                      <span class="radio-circle"></span>
                    </label>
                    <label class="option-item">
                      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4"/><path d="M12 8h.01"/></svg>
                      <span class="option-text">Other</span>
                      <input type="radio" name="business_type" value="other" />
                      <span class="radio-circle"></span>
                    </label>
                  </div>
                </div>

                <!-- Step 2: Property Details -->
                <div class="step-panel" data-step="2">
                  <div class="form-fields">
                    <div class="form-group">
                      <label for="property_name">Enter your property name <span class="req">*</span></label>
                      <input type="text" id="property_name" name="property_name" placeholder="Property name" required />
                    </div>
                    <div class="form-group">
                      <label for="property_type">Your property is...</label>
                      <select id="property_type" name="property_type">
                        <option value="" disabled selected>Select property type</option>
                        <option value="independent">Independent Property</option>
                        <option value="chain">Hotel Chain / Group</option>
                        <option value="management">Management Company</option>
                        <option value="franchise">Franchise</option>
                      </select>
                    </div>
                    <div class="form-group">
                      <label for="rooms">How many rooms do you have? <span class="req">*</span></label>
                      <input type="number" id="rooms" name="rooms" placeholder="e.g. 50" min="1" required />
                    </div>
                    <div class="form-group">
                      <label for="country">Property Country</label>
                      <select id="country" name="country">
                        <option value="" disabled selected>Select country</option>
                        <option value="KE">Kenya</option>
                        <option value="TZ">Tanzania</option>
                        <option value="UG">Uganda</option>
                        <option value="RW">Rwanda</option>
                        <option value="ET">Ethiopia</option>
                        <option value="NG">Nigeria</option>
                        <option value="GH">Ghana</option>
                        <option value="ZA">South Africa</option>
                        <option value="other">Other</option>
                      </select>
                    </div>
                  </div>
                </div>

                <!-- Step 3: Contact Info -->
                <div class="step-panel" data-step="3">
                  <div class="form-fields">
                    <div class="form-group">
                      <label for="full_name">Name</label>
                      <input type="text" id="full_name" name="full_name" placeholder="Full name" required />
                    </div>
                    <div class="form-group">
                      <label for="job_role">Job Role</label>
                      <select id="job_role" name="job_role">
                        <option value="" disabled selected>Select a Job Role</option>
                        <option value="gm">General Manager</option>
                        <option value="owner">Owner</option>
                        <option value="revenue">Revenue Manager</option>
                        <option value="front_office">Front Office Manager</option>
                        <option value="it">IT Manager</option>
                        <option value="fd">Front Desk Manager</option>
                        <option value="other">Other</option>
                      </select>
                    </div>
                    <div class="form-group">
                      <label for="email">Email</label>
                      <input type="email" id="email" name="email" placeholder="Enter email" required />
                    </div>
                    <div class="form-group">
                      <label for="phone">Phone Number</label>
                      <div class="phone-input-group">
                        <select class="phone-prefix" name="phone_prefix">
                          <option value="+254">🇰🇪 +254</option>
                          <option value="+255">🇹🇿 +255</option>
                          <option value="+256">🇺🇬 +256</option>
                          <option value="+250">🇷🇼 +250</option>
                          <option value="+251">🇪🇹 +251</option>
                          <option value="+234">🇳🇬 +234</option>
                          <option value="+233">🇬🇭 +233</option>
                          <option value="+27">🇿🇦 +27</option>
                        </select>
                        <input type="tel" id="phone" name="phone" placeholder="Enter phone number" />
                      </div>
                    </div>
                    <div class="form-group">
                      <label for="language">Preferred Language</label>
                      <select id="language" name="language">
                        <option value="en">English</option>
                        <option value="sw">Swahili</option>
                        <option value="fr">French</option>
                      </select>
                    </div>
                    <div class="consent-group">
                      <label class="checkbox-label">
                        <input type="checkbox" name="consent" />
                        <span class="checkbox-text">By checking, you are allowing us to receive transactional/informational SMS communications from HotelWise. Frequency may vary. Message and data rates may apply. Read our <a href="#">Terms & Conditions</a> · <a href="#">Privacy Policy</a>.</span>
                      </label>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <!-- Static Navigation -->
          <div class="step-nav">
            <button type="button" class="btn-back" id="btn-back" style="visibility: hidden;">&larr; Back</button>
            <span class="step-indicator" id="step-indicator">1 of 3</span>
            <button type="button" class="btn-next" id="btn-next">Next <span>&rarr;</span></button>
          </div>
        </form>
      </div>
    </div>

    <!-- Testimonial + Stats Row -->
    <div class="social-strip">
      <div class="container social-strip-inner">
        <!-- Testimonial -->
        <div class="strip-testimonial">
          <div class="testimonial-avatar">
            <span>👤</span>
          </div>
          <div class="testimonial-text">
            <blockquote>"When HotelWise came along, the front desk staff started being able to look the guests in the eye. People can focus more on the people and less on the computer."</blockquote>
            <div class="testimonial-author">
              <strong>Jane Muthoni</strong>
              <span>Revenue Manager at Nairobi Hotels Group</span>
            </div>
          </div>
        </div>
        <!-- Stats -->
        <div class="strip-stats">
          <div class="strip-stat">
            <span class="stat-num">20%</span>
            <span class="stat-label">Increase in direct bookings</span>
          </div>
          <div class="strip-stat">
            <span class="stat-num">300+</span>
            <span class="stat-label">Built-in channels</span>
          </div>
          <div class="strip-stat">
            <span class="stat-num">32%</span>
            <span class="stat-label">Lift in positive reviews</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Trust Bar -->
    <div class="trust-bar">
      <div class="container trust-bar-inner">
        <p>Trusted by leading hotels, hospitality groups, and management companies across East Africa.</p>
        <div class="trust-logos">
          <span>Sarova Hotels</span>
          <span>Tribe Hotel</span>
          <span>Enashipai</span>
          <span>PrideInn</span>
          <span>Hemingways</span>
        </div>
      </div>
    </div>
  </main>

  <Footer />
</Layout>

<script>
  import { gsap } from "gsap";

  const form = document.getElementById('demo-form');
  const panels = document.querySelectorAll('.step-panel');
  const subtitle = document.getElementById('step-subtitle');
  const indicator = document.getElementById('step-indicator');
  const btnBack = document.getElementById('btn-back') as HTMLButtonElement;
  const btnNext = document.getElementById('btn-next') as HTMLButtonElement;
  let currentStep = 1;
  const totalSteps = 3;

  const subtitles: Record<number, string> = {
    1: 'Which best describes your business?',
    2: "Let's get some details about your property",
    3: 'Last step, a little about you'
  };

  // Entrance animation
  gsap.from('.form-area', { opacity: 0, duration: 0.6, ease: 'power2.out' });

  function updateNav() {
    if (indicator) indicator.textContent = `${currentStep} of ${totalSteps}`;
    if (btnBack) btnBack.style.visibility = currentStep === 1 ? 'hidden' : 'visible';
    if (btnNext) {
      if (currentStep === totalSteps) {
        btnNext.innerHTML = 'Submit <span>&rarr;</span>';
        btnNext.setAttribute('type', 'submit');
      } else {
        btnNext.innerHTML = 'Next <span>&rarr;</span>';
        btnNext.setAttribute('type', 'button');
      }
    }
  }

  function goToStep(targetStep: number) {
    if (targetStep < 1 || targetStep > totalSteps || targetStep === currentStep) return;

    const currentPanel = document.querySelector(`.step-panel[data-step="${currentStep}"]`) as HTMLElement;
    const targetPanel = document.querySelector(`.step-panel[data-step="${targetStep}"]`) as HTMLElement;
    if (!currentPanel || !targetPanel) return;

    const direction = targetStep > currentStep ? 1 : -1;

    // Animate subtitle text
    gsap.to(subtitle, {
      opacity: 0,
      y: -6,
      duration: 0.15,
      onComplete: () => {
        if (subtitle) subtitle.textContent = subtitles[targetStep];
        gsap.to(subtitle, { opacity: 1, y: 0, duration: 0.25, ease: 'power2.out' });
      }
    });

    // Animate only the panel content
    gsap.to(currentPanel, {
      x: direction * -60,
      opacity: 0,
      duration: 0.3,
      ease: 'power2.in',
      onComplete: () => {
        currentPanel.classList.remove('active');

        gsap.set(targetPanel, { x: direction * 60, opacity: 0 });
        targetPanel.classList.add('active');

        gsap.to(targetPanel, {
          x: 0,
          opacity: 1,
          duration: 0.4,
          ease: 'power2.out'
        });
      }
    });

    currentStep = targetStep;
    updateNav();
  }

  // Next button
  btnNext?.addEventListener('click', (e) => {
    if (currentStep < totalSteps) {
      e.preventDefault();
      goToStep(currentStep + 1);
    }
    // If currentStep === totalSteps, let the form submit naturally
  });

  // Back button
  btnBack?.addEventListener('click', () => {
    goToStep(currentStep - 1);
  });

  // Radio option selection visual feedback
  document.querySelectorAll('.option-item input[type="radio"]').forEach(radio => {
    radio.addEventListener('change', () => {
      document.querySelectorAll('.option-item').forEach(item => item.classList.remove('selected'));
      (radio as HTMLElement).closest('.option-item')?.classList.add('selected');
    });
  });

  // Form submit
  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    const formData = new FormData(form as HTMLFormElement);
    const data = Object.fromEntries(formData.entries());
    console.log('Demo request:', data);
    
    const formArea = document.querySelector('.form-wrapper') as HTMLElement;
    if (formArea) {
      gsap.to(formArea, {
        opacity: 0,
        y: -20,
        duration: 0.3,
        onComplete: () => {
          formArea.innerHTML = `
            <div class="success-state">
              <div class="success-icon">✓</div>
              <h2>Thank you!</h2>
              <p>We've received your demo request. Our team will be in touch within 24 hours to schedule your personalized walkthrough.</p>
              <a href="/" class="btn-back-home">Back to homepage</a>
            </div>
          `;
          gsap.from(formArea, { opacity: 0, y: 20, duration: 0.5, ease: 'power2.out' });
        }
      });
    }
  });
</script>

<style>
  /* ── Header ── */
  .minimal-header {
    border-bottom: 1px solid var(--border-color);
    background: #fff;
  }
  .header-inner {
    height: 64px;
    display: flex;
    align-items: center;
  }
  .logo {
    display: flex;
    align-items: center;
    gap: 8px;
    font-weight: 700;
    font-size: 1.25rem;
  }
  .logo-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 24px;
    height: 24px;
    background: var(--text-primary);
    color: white;
    border-radius: 4px;
    font-size: 14px;
  }

  /* ── Form Area ── */
  .form-area {
    background: #BFDEFF;
    min-height: 620px;
    display: flex;
    align-items: stretch;
  }
  .form-wrapper {
    width: 100%;
    max-width: 960px;
    margin: 0 auto;
    padding: 60px 40px;
    position: relative;
  }
  .multi-step-form {
    position: relative;
    height: 100%;
    display: flex;
    flex-direction: column;
  }

  /* ── Steps ── */
  .step-panel {
    display: none;
    flex-direction: column;
    flex: 1;
  }
  .step-panel.active {
    display: flex;
  }

  .step-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 64px;
    flex: 1;
  }
  .step-left {
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
    padding-top: 16px;
  }
  .step-left h1 {
    font-size: 2rem;
    font-weight: 400;
    color: #111;
    margin-bottom: 16px;
  }
  .step-subtitle {
    font-size: 1.0625rem;
    color: #444;
    line-height: 1.5;
  }

  /* ── Radio Options (Step 1) ── */
  .option-list {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .option-item {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 18px 20px;
    background: #fff;
    border: 1px solid rgba(0,0,0,0.1);
    border-radius: 4px;
    cursor: pointer;
    transition: border-color 0.2s, box-shadow 0.2s;
    position: relative;
  }
  .option-item:hover {
    border-color: #111;
  }
  .option-item.selected {
    border-color: #111;
    box-shadow: 0 0 0 1px #111;
  }
  .option-item svg {
    flex-shrink: 0;
    color: #333;
  }
  .option-text {
    flex: 1;
    font-size: 1rem;
    font-weight: 500;
    color: #111;
  }
  .option-item input[type="radio"] {
    position: absolute;
    opacity: 0;
    width: 0;
    height: 0;
  }
  .radio-circle {
    width: 20px;
    height: 20px;
    border: 2px solid rgba(0,0,0,0.2);
    border-radius: 50%;
    flex-shrink: 0;
    position: relative;
    transition: border-color 0.2s;
  }
  .option-item.selected .radio-circle {
    border-color: #111;
  }
  .option-item.selected .radio-circle::after {
    content: '';
    position: absolute;
    top: 3px;
    left: 3px;
    width: 10px;
    height: 10px;
    background: #111;
    border-radius: 50%;
  }

  /* ── Form Fields (Steps 2 & 3) ── */
  .form-fields {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }
  .form-group {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .form-group label {
    font-size: 0.875rem;
    font-weight: 600;
    color: #111;
  }
  .req {
    color: #e53e3e;
  }
  .form-group input,
  .form-group select {
    padding: 16px;
    border: 1px solid rgba(0,0,0,0.12);
    border-radius: 4px;
    font-family: inherit;
    font-size: 1rem;
    background: #fff;
    color: #111;
    transition: border-color 0.2s, box-shadow 0.2s;
    appearance: auto;
  }
  .form-group input:focus,
  .form-group select:focus {
    outline: none;
    border-color: #111;
    box-shadow: 0 0 0 1px #111;
  }
  .form-group input::placeholder {
    color: #999;
  }

  /* Phone input */
  .phone-input-group {
    display: flex;
    gap: 0;
    border: 1px solid rgba(0,0,0,0.12);
    border-radius: 4px;
    overflow: hidden;
    background: #fff;
  }
  .phone-input-group:focus-within {
    border-color: #111;
    box-shadow: 0 0 0 1px #111;
  }
  .phone-prefix {
    padding: 16px 8px 16px 16px;
    border: none;
    background: transparent;
    font-size: 1rem;
    font-family: inherit;
    color: #111;
    min-width: 110px;
    border-right: 1px solid rgba(0,0,0,0.08);
  }
  .phone-prefix:focus {
    outline: none;
  }
  .phone-input-group input {
    flex: 1;
    border: none !important;
    box-shadow: none !important;
    padding: 16px;
  }

  /* Consent */
  .consent-group {
    margin-top: 8px;
  }
  .checkbox-label {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    cursor: pointer;
  }
  .checkbox-label input[type="checkbox"] {
    margin-top: 4px;
    width: 16px;
    height: 16px;
    flex-shrink: 0;
    accent-color: #111;
  }
  .checkbox-text {
    font-size: 0.75rem;
    color: #555;
    line-height: 1.5;
  }
  .checkbox-text a {
    color: #111;
    text-decoration: underline;
  }

  /* ── Step Navigation ── */
  .step-nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: 48px;
    padding-top: 24px;
  }
  .step-indicator {
    font-size: 0.9375rem;
    color: #555;
  }
  .btn-next {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    padding: 16px 32px;
    background: #fcf18d;
    color: #111;
    border: none;
    font-size: 1rem;
    font-weight: 600;
    cursor: pointer;
    transition: background 0.2s, transform 0.1s;
    font-family: inherit;
  }
  .btn-next:hover {
    background: #f5e84d;
  }
  .btn-next:active {
    transform: scale(0.98);
  }
  .btn-back {
    background: none;
    border: none;
    font-size: 1rem;
    font-weight: 500;
    color: #111;
    cursor: pointer;
    padding: 0;
    font-family: inherit;
    transition: opacity 0.2s;
  }
  .btn-back:hover {
    opacity: 0.6;
  }

  /* ── Social Strip ── */
  .social-strip {
    background: #fff;
    padding: 60px 0;
    border-bottom: 1px solid rgba(0,0,0,0.08);
  }
  .social-strip-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 64px;
    align-items: start;
  }
  .strip-testimonial {
    display: flex;
    gap: 24px;
  }
  .testimonial-avatar {
    width: 56px;
    height: 56px;
    background: #f0f0f0;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.25rem;
    flex-shrink: 0;
  }
  .strip-testimonial blockquote {
    font-family: var(--font-serif);
    font-size: 0.9375rem;
    line-height: 1.65;
    color: #111;
    margin: 0 0 20px 0;
    text-align: left;
  }
  .testimonial-author strong {
    display: block;
    font-size: 0.875rem;
    font-weight: 600;
  }
  .testimonial-author span {
    font-size: 0.8125rem;
    color: #666;
  }
  .strip-stats {
    display: flex;
    gap: 0;
  }
  .strip-stat {
    flex: 1;
    padding: 24px;
    background: #fafaf5;
    display: flex;
    flex-direction: column;
    gap: 8px;
    border-right: 1px solid rgba(0,0,0,0.06);
  }
  .strip-stat:last-child {
    border-right: none;
  }
  .stat-num {
    font-size: 2.25rem;
    font-weight: 400;
    letter-spacing: -0.02em;
    color: #111;
  }
