---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Button from '../components/Button';
---

<Layout title="Hotel Management System">
  <Header />
  <main>
    <div class="hero-wrapper">
      <section class="hero container">
      <div class="hero-content">
        <h1 class="hero-title">One tool to run your hospitality business.</h1>
        <p class="hero-subtitle">Hotel software built around how a hotel actually runs. From front desk to back office, in one system — in real time.</p>
        <div class="hero-actions">
          <Button href="/demo" variant="primary" client:load>Book a Demo</Button>
          <Button href="/features" variant="secondary" client:load>See Features</Button>
        </div>
        <p class="hero-trust">Trusted by hotels, restaurants, bars, clubs, and wine & spirit outlets.</p>
      </div>
      <div class="hero-visual">
        <div class="visual-placeholder">
          <img src="https://images.unsplash.com/photo-1566073771259-6a8506099945?auto=format&fit=crop&w=800&q=80" alt="HotelWise dashboard" style="width: 100%; height: 100%; object-fit: cover; border-radius: inherit;" />
        </div>
      </div>
      </section>
    </div>

    <section class="social-proof-section">
      <div class="container proof-header">
        <p class="proof-heading">Trusted by leading hotels, hospitality groups, and<br/>management companies across East Africa.</p>
        <Button href="/customers" variant="outline" client:load>Hotelier Stories &nearr;</Button>
      </div>

      <!-- Logo Marquee -->
      <div class="logo-marquee">
        <div class="marquee-track">
          <span class="logo-text">Serena Hotels</span>
          <span class="logo-text">Hemingways</span>
          <span class="logo-text">Sarova</span>
          <span class="logo-text">Tamarind</span>
          <span class="logo-text">Sankara</span>
          <span class="logo-text">Fairmont</span>
          <span class="logo-text">Radisson</span>
          <span class="logo-text">PrideInn</span>
          <!-- Duplicate for seamless loop -->
          <span class="logo-text">Serena Hotels</span>
          <span class="logo-text">Hemingways</span>
          <span class="logo-text">Sarova</span>
          <span class="logo-text">Tamarind</span>
          <span class="logo-text">Sankara</span>
          <span class="logo-text">Fairmont</span>
          <span class="logo-text">Radisson</span>
          <span class="logo-text">PrideInn</span>
        </div>
      </div>

      <!-- Stats + Carousel Layout -->
      <div class="proof-carousel-area">
        <div class="proof-stats">
          <div class="stat-group">
            <span class="stat-number">0%</span>
            <span class="stat-text">Quarterly surge</span>
          </div>
          <div class="stat-group">
            <span class="stat-number">0</span>
            <span class="stat-text">Properties operated</span>
          </div>
          <div class="stat-group">
            <span class="stat-number">0</span>
            <span class="stat-text">More properties planned</span>
          </div>
        </div>

        <div class="testimonial-carousel">
          <div class="carousel-controls">
            <button class="control-btn" aria-label="Previous">&larr;</button>
            <button class="control-btn" aria-label="Next">&rarr;</button>
          </div>
          <div class="testimonial-cards-wrapper">
            <!-- Review 1 -->
            <div class="testimonial-card">
              <div class="testimonial-content">
                <div class="author-photo">
                   <span class="photo-placeholder">👤</span>
                </div>
                <blockquote>
                  "HotelWise is built to make everything as simple as possible, but with the level of complexity that is needed for complex operations like ours."
                </blockquote>
                <div class="author-info">
                  <strong>Mario Simancas</strong>
                  <span>Sales and Marketing Lead, Iray Group</span>
                </div>
              </div>
              <div class="testimonial-metrics">
                <div class="metric-item">
                  <span class="metric-value">15%</span>
                  <span class="metric-label">Increase in ADR</span>
                </div>
                <div class="metric-item">
                  <span class="metric-value">74%</span>
                  <span class="metric-label">Occupancy rate</span>
                </div>
                <div class="metric-item">
                  <span class="metric-value">10</span>
                  <span class="metric-label">Return on investment</span>
                </div>
              </div>
            </div>
            
            <!-- Review 2 -->
            <div class="testimonial-card hidden">
              <div class="testimonial-content">
                <div class="author-photo">
                   <span class="photo-placeholder">👤</span>
                </div>
                <blockquote>
                  "Our seven year partnership with HotelWise is a commitment to understanding our unique feedback and ensuring our perspectives are heard."
                </blockquote>
                <div class="author-info">
                  <strong>Bojan Tegovski</strong>
                  <span>Chief Operating Officer, HP Hospitality</span>
                </div>
              </div>
              <div class="testimonial-metrics">
                <div class="metric-item">
                  <span class="metric-value">28%</span>
                  <span class="metric-label">RevPAR increase</span>
                </div>
                <div class="metric-item">
                  <span class="metric-value">30%</span>
                  <span class="metric-label">Reduction in OTA reliance</span>
                </div>
                <div class="metric-item">
                  <span class="metric-value">5</span>
                  <span class="metric-label">New hotel openings planned</span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="features-preview container">
      <h2 class="section-title text-center">Everything you need, nothing you don't.</h2>
      <div class="features-grid">
        <div class="feature-card">
          <div class="card-icon"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10.268 21a2 2 0 0 0 3.464 0"/><path d="M22.7 17a8.4 8.4 0 0 0-4.7-7V9a6 6 0 0 0-12 0v1a8.4 8.4 0 0 0-4.7 7 1 1 0 0 0 1 1.5h20.4a1 1 0 0 0 1-1.5z"/></svg></div>
          <div class="card-content">
            <h3>Front Desk</h3>
            <p>Check arriving guests in, open folios, and manage transactions.</p>
            <a href="/features#front-desk" class="card-link">HotelWise for Front Desk &rarr;</a>
          </div>
        </div>
        <div class="feature-card">
          <div class="card-icon"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 2v7c0 1.1.9 2 2 2h4a2 2 0 0 0 2-2V2"/><path d="M7 2v20"/><path d="M21 15V2v0a5 5 0 0 0-5 5v6c0 1.1.9 2 2 2h3Zm0 0v7"/></svg></div>
          <div class="card-content">
            <h3>Restaurant POS</h3>
            <p>Order-taking and billing, posting directly to guest folios.</p>
            <a href="/features#restaurant" class="card-link">HotelWise for Restaurants &rarr;</a>
          </div>
        </div>
        <div class="feature-card">
          <div class="card-icon"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 3v18h18"/><path d="M18 17V9"/><path d="M13 17V5"/><path d="M8 17v-3"/></svg></div>
          <div class="card-content">
            <h3>Accounting</h3>
            <p>Automatic posting to a full hotel-specific chart of accounts.</p>
            <a href="/features#accounting" class="card-link">HotelWise for Accounting &rarr;</a>
          </div>
        </div>
      </div>
      <div class="text-center" style="margin-top: 3rem;">
        <Button href="/features" variant="outline" client:load>View all 9 modules</Button>
      </div>
    </section>

    <!-- FAQ Section -->
    <section class="faq-section">
      <div class="container">
      <div class="faq-inner">
        <h2>Got a question?</h2>
        <div class="faq-list">
          <!-- FAQ Item 1 -->
          <div class="faq-item">
            <button class="faq-toggle" aria-expanded="false">
              <span class="faq-question">What is HotelWise?</span>
              <span class="faq-icon plus">+</span>
            </button>
            <div class="faq-content">
              <p>HotelWise is the operating system built to power modern hospitality businesses across East Africa. It connects every part of property operations, from reservations and payments to housekeeping and stores. With HotelWise, properties can unlock new revenue, reduce manual work and adapt fast to whatever comes next.</p>
            </div>
          </div>
          <!-- FAQ Item 2 -->
          <div class="faq-item">
            <button class="faq-toggle" aria-expanded="false">
              <span class="faq-question">Which types of hospitality businesses can benefit from using HotelWise?</span>
              <span class="faq-icon plus">+</span>
            </button>
            <div class="faq-content">
              <p>Hotels, resorts, lodges, restaurants, bars, and clubs all benefit from HotelWise's all-in-one suite. Our modular approach lets you use exactly what you need.</p>
            </div>
          </div>
          <!-- FAQ Item 3 -->
          <div class="faq-item">
            <button class="faq-toggle" aria-expanded="false">
              <span class="faq-question">What features does HotelWise offer for hotel management?</span>
              <span class="faq-icon plus">+</span>
            </button>
            <div class="faq-content">
              <p>We provide Front Desk operations, Restaurant POS, fully integrated Accounting, Housekeeping, Store management, and comprehensive reporting across all departments.</p>
            </div>
          </div>
          <!-- FAQ Item 4 -->
          <div class="faq-item">
            <button class="faq-toggle" aria-expanded="false">
              <span class="faq-question">How does HotelWise streamline hotel management processes and revenue generation?</span>
              <span class="faq-icon plus">+</span>
            </button>
            <div class="faq-content">
              <p>By connecting all departments to a single source of truth, HotelWise eliminates double data entry and reduces billing errors. Staff can instantly see room status, post charges from the restaurant, and access real-time financial reporting, leading to a leaner operation and higher margins.</p>
            </div>
          </div>
        </div>
      </div>
      </div>
    </section>

  </main>
  <Footer />
</Layout>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  // Hero animations
  gsap.from(".hero-title", { y: 30, opacity: 0, duration: 0.8, ease: "power3.out" });
  gsap.from(".hero-subtitle", { y: 20, opacity: 0, duration: 0.8, ease: "power3.out", delay: 0.1 });
  gsap.from(".hero-actions", { y: 20, opacity: 0, duration: 0.8, ease: "power3.out", delay: 0.2 });
  gsap.from(".hero-visual", { y: 40, opacity: 0, duration: 1, ease: "power3.out", delay: 0.3 });
  
  // Social Proof animations
  gsap.from(".proof-header", {
    scrollTrigger: { trigger: ".social-proof-section", start: "top 80%" },
    y: 20, opacity: 0, duration: 0.8, ease: "power3.out"
  });
  gsap.from(".logo-marquee", {
    scrollTrigger: { trigger: ".logo-marquee", start: "top 90%" },
    opacity: 0, duration: 1, ease: "power2.out"
  });
  gsap.from(".proof-stats .stat-group", {
    scrollTrigger: { trigger: ".proof-row", start: "top 85%" },
    x: -30, opacity: 0, duration: 0.6, stagger: 0.12, ease: "power2.out"
  });
  gsap.from(".testimonial-carousel", {
    scrollTrigger: { trigger: ".proof-row", start: "top 85%" },
    y: 30, opacity: 0, duration: 0.8, ease: "power3.out", delay: 0.2
  });

  // Scroll animations for features
  gsap.from(".feature-card", {
    scrollTrigger: {
      trigger: ".features-grid",
      start: "top 80%",
    },
    y: 40,
    opacity: 0,
    duration: 0.6,
    stagger: 0.1,
    ease: "power2.out"
  });

  // Carousel Logic
  const cards = document.querySelectorAll('.testimonial-card');
  const prevBtn = document.querySelector('.carousel-controls .control-btn:first-child');
  const nextBtn = document.querySelector('.carousel-controls .control-btn:last-child');
  let currentCard = 0;

  if (prevBtn && nextBtn && cards.length > 0) {
    const updateCards = () => {
      cards.forEach((card, index) => {
        if (index === currentCard) {
          card.classList.remove('hidden');
          gsap.fromTo(card, { opacity: 0, x: 20 }, { opacity: 1, x: 0, duration: 0.4 });
        } else {
          card.classList.add('hidden');
        }
      });
    };

    prevBtn.addEventListener('click', () => {
      currentCard = (currentCard - 1 + cards.length) % cards.length;
      updateCards();
    });
    
    nextBtn.addEventListener('click', () => {
      currentCard = (currentCard + 1) % cards.length;
      updateCards();
    });
  }

  // FAQ Logic
  const faqToggles = document.querySelectorAll('.faq-toggle');
  faqToggles.forEach(toggle => {
    toggle.addEventListener('click', () => {
      const parent = toggle.closest('.faq-item');
      const icon = toggle.querySelector('.faq-icon');
      const content = parent.querySelector('.faq-content');
      const isActive = parent.classList.contains('active');
      
      // Close all
      document.querySelectorAll('.faq-item').forEach(item => {
        if (item.classList.contains('active')) {
          item.classList.remove('active');
          const itemIcon = item.querySelector('.faq-icon');
          if (itemIcon) {
            itemIcon.textContent = '+';
            itemIcon.classList.remove('minus');
            itemIcon.classList.add('plus');
          }
          item.querySelector('.faq-toggle').setAttribute('aria-expanded', 'false');
          gsap.to(item.querySelector('.faq-content'), { height: 0, opacity: 0, duration: 0.4, ease: "power2.inOut" });
        }
      });
      
      // If it wasn't active, open it
      if (!isActive) {
        parent.classList.add('active');
        toggle.setAttribute('aria-expanded', 'true');
        icon.textContent = '-';
        icon.classList.remove('plus');
        icon.classList.add('minus');
        gsap.to(content, { height: "auto", opacity: 1, duration: 0.4, ease: "power2.inOut" });
      }
    });
  });
</script>

<style>
  .hero-wrapper {
    position: relative;
    width: 100%;
  }
  .hero-wrapper::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background-size: 80px 80px;
    background-position: center top;
    background-image: 
      linear-gradient(to right, rgba(0,0,0,0.035) 1px, transparent 1px),
      linear-gradient(to bottom, rgba(0,0,0,0.035) 1px, transparent 1px);
    mask-image: linear-gradient(to bottom, black 60%, transparent 100%);
    -webkit-mask-image: linear-gradient(to bottom, black 60%, transparent 100%);
    z-index: -1;
    pointer-events: none;
  }
  .hero {
    padding: var(--spacing-xl) var(--spacing-lg) var(--spacing-lg);
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--spacing-lg);
  }
  .hero-content {
    max-width: 800px;
  }
  .hero-title {
    font-size: 4.5rem;
    margin-bottom: var(--spacing-md);
  }
  .hero-subtitle {
    font-size: 1.25rem;
    color: var(--text-secondary);
    margin-bottom: var(--spacing-lg);
    text-wrap: balance;
  }
  .hero-actions {
    display: flex;
    gap: var(--spacing-sm);
    justify-content: center;
    margin-bottom: var(--spacing-md);
  }
  .hero-trust {
    font-size: 0.875rem;
    color: var(--text-tertiary);
  }
  .hero-visual {
    width: 100%;
    max-width: 1000px;
    aspect-ratio: 16 / 9;
    border-radius: var(--radius-lg);
    overflow: hidden;
    border: 1px solid var(--border-color);
    background: var(--bg-secondary);
    box-shadow: var(--shadow-lg);
  }
  .visual-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .placeholder-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--spacing-sm);
    color: var(--text-tertiary);
  }
  .placeholder-icon {
    font-size: 3rem;
  }
  
  /* ── Social Proof Section ── */
  .social-proof-section {
    padding: 80px 0 100px;
    background: var(--bg-primary);
  }
  .proof-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 48px;
  }
  .proof-heading {
    font-weight: 500;
    color: var(--text-primary);
    font-size: 1.125rem;
    line-height: 1.5;
    margin: 0;
  }
  
  /* ── Logo Marquee ── */
  .logo-marquee {
    overflow: hidden;
    max-width: 900px;
    margin: 0 auto 56px;
    mask-image: linear-gradient(to right, transparent 0%, black 12%, black 88%, transparent 100%);
    -webkit-mask-image: linear-gradient(to right, transparent 0%, black 12%, black 88%, transparent 100%);
  }
  .marquee-track {
    display: flex;
    align-items: center;
    gap: 72px;
    width: max-content;
    animation: marquee 30s linear infinite;
  }
  .logo-text {
    font-weight: 700;
    font-size: 1.35rem;
    letter-spacing: -0.02em;
    font-family: var(--font-serif);
    color: var(--text-primary);
    opacity: 0.35;
    white-space: nowrap;
    flex-shrink: 0;
    transition: opacity 0.3s;
  }
  .logo-text:hover {
    opacity: 0.7;
  }
  @keyframes marquee {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  /* ── Stats + Carousel Area ── */
  .proof-carousel-area {
    position: relative;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 var(--spacing-lg) 0 160px; /* leave room for stats on the left */
  }
  
  .proof-stats {
    position: absolute;
    left: 0;
    top: 48px;
    display: flex;
    flex-direction: column;
    gap: 36px;
    width: 120px;
  }
  .stat-group {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .stat-number {
    font-size: 2.5rem;
    font-weight: 300;
    line-height: 1;
    color: var(--text-primary);
    font-family: var(--font-serif);
  }
  .stat-text {
    font-size: 0.6875rem;
    color: rgba(0,0,0,0.35);
    line-height: 1.4;
    text-transform: capitalize;
  }

  /* ── Carousel ── */
  .testimonial-carousel {
    position: relative;
  }
  .carousel-controls {
    display: flex;
    justify-content: flex-end;
    gap: 20px;
    margin-bottom: 16px;
  }
  .control-btn {
    background: none;
    border: none;
    font-size: 1.5rem;
    color: var(--text-primary);
    cursor: pointer;
    transition: opacity 0.2s;
    padding: 0;
  }
  .control-btn:hover {
    opacity: 0.5;
  }
  
  .testimonial-cards-wrapper {
    position: relative;
    width: 100%;
  }
  .testimonial-card {
    background: #f5f5ec;
    border-radius: 8px;
    display: grid;
    grid-template-columns: 5fr 2fr;
    overflow: hidden;
    min-height: 0;
  }
  .testimonial-card.hidden {
    display: none;
  }
  
  .testimonial-content {
    padding: 40px 48px;
    display: flex;
    flex-direction: column;
    gap: 20px;
  }
  .author-photo {
    width: 56px;
    height: 56px;
    background: #e0ddd4;
    border-radius: 6px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.25rem;
  }
  .testimonial-content blockquote {
    font-family: var(--font-serif);
    font-size: 1.0625rem;
    line-height: 1.65;
    color: var(--text-primary);
    margin: 0;
    text-align: left;
  }
  .author-info {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .author-info strong {
    font-size: 0.9375rem;
    font-weight: 600;
  }
  .author-info span {
    font-size: 0.8125rem;
    color: var(--text-secondary);
  }
  
  .testimonial-metrics {
    padding: 40px 36px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 28px;
    border-left: 1px solid rgba(0,0,0,0.06);
  }
  .metric-item {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .metric-value {
    font-size: 2.75rem;
    font-weight: 400;
    line-height: 1;
    letter-spacing: -0.02em;
  }
  .metric-label {
    font-size: 0.75rem;
    font-weight: 500;
    color: rgba(0,0,0,0.4);
  }

  /* ── Features ── */
  .section-title {
    margin-bottom: 64px;
  }
  .features-preview {
    padding: 100px var(--spacing-lg);
  }
  .features-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 24px;
  }
  .feature-card {
    background: #f4f5f7;
    border-radius: 12px;
    padding: 40px 32px;
    display: flex;
    flex-direction: column;
    border: none;
    box-shadow: none;
  }
  .card-icon {
    width: 44px;
    height: 44px;
    background: #e5e7eb;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #111;
    margin-bottom: 24px;
  }
  .card-content {
    display: flex;
    flex-direction: column;
    flex-grow: 1;
  }
  .feature-card h3 {
    font-size: 1.25rem;
    font-weight: 700;
    margin-bottom: 12px;
    color: #111;
  }
  .feature-card p {
    color: #4a4a4a;
    font-size: 0.9375rem;
    line-height: 1.6;
    margin-bottom: 32px;
    flex-grow: 1;
  }
  .card-link {
    font-size: 0.6875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: #111;
    text-decoration: none;
    display: inline-block;
    transition: opacity 0.2s;
  }
  .card-link:hover {
    opacity: 0.7;
  }
  
  /* ── FAQ ── */
  .faq-section {
    padding: 80px var(--spacing-lg) 120px;
    background: #F8FBED;
  }
  .faq-inner {
    max-width: 720px;
    margin: 0 auto;
  }
  .faq-inner h2 {
    font-size: 2.25rem;
    font-weight: 700;
    margin-bottom: 48px;
    color: var(--text-primary);
  }
  .faq-item {
    border-top: 1px solid rgba(0,0,0,0.1);
  }
  .faq-item:last-child {
    border-bottom: 1px solid rgba(0,0,0,0.1);
  }
  .faq-toggle {
    width: 100%;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 24px 0;
    background: none;
    border: none;
    cursor: pointer;
    text-align: left;
    color: var(--text-primary);
    gap: 24px;
  }
  .faq-question {
    font-size: 1.0625rem;
    font-weight: 600;
