---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Button from '../components/Button';
---

<Layout title="About HotelWise">
  <Header />
  <main class="about-page">

    <!-- Hero -->
    <div class="hero-wrapper">
      <section class="about-hero container">
      <div class="hero-left">
        <div class="pill-badge">
          <span class="pill-icon"></span> About us
        </div>
        <h1>Hi, we're Suluhu Technologies.</h1>
        <p class="hero-lead">We are not here to add clutter.<br/>We are here to help you focus<br/>on what matters.</p>
      </div>
      <div class="hero-image">
        <div class="image-placeholder">
          <img src="https://images.unsplash.com/photo-1556761175-5973dc0f32b7?auto=format&fit=crop&w=800&q=80" alt="HotelWise Team" style="width: 100%; height: 100%; object-fit: cover; border-radius: inherit;" />
        </div>
      </div>
      </section>
    </div>

    <!-- Mission -->
    <section class="mission-section">
      <div class="container">
        <div class="mission-content">
          <div class="pill-badge">
            <span class="pill-icon"></span> Our mission
          </div>
          <h2 class="mission-heading">Support better hospitality</h2>
          <p class="mission-body">Our mission is to create seamless software that allows staff to focus on what matters, actually interacting with guests and each other, instead of fiddling with complicated tools.</p>
          <p class="mission-body">When the system stays out of the way, hospitality can happen naturally.</p>
          <p class="mission-body">That's the only reason HotelWise exists.</p>
        </div>
      </div>
    </section>

    <div class="divider"></div>

    <!-- Our Story -->
    <section class="story-section container">
      <div class="story-header-content">
        <div class="pill-badge" style="background: transparent; padding: 0; margin-bottom: 24px;">
          <span class="pill-icon" style="background: #9bd0ff;"></span> Our story
        </div>
        <h2 class="story-heading" style="margin-bottom: 32px; font-weight: 400; font-family: var(--font-sans);">Hospitality deserved better.<br/>So we built it.</h2>
      </div>
      <div class="story-card" style="background: #fcf18d; padding: 36px 40px; border-radius: 8px;">
        <div class="story-grid" style="margin-bottom: 0; gap: 48px; align-items: center;">
          <div class="story-text" style="color: #1a1a1a;">
            <p style="color: inherit;">Hotels across East Africa were stuck choosing between expensive enterprise systems designed for global chains and fragile spreadsheets held together with willpower. Neither option respected the reality of running a 50-room lodge or a standalone restaurant.</p>
            <p style="color: inherit;">We started HotelWise in Kenya with a simple thesis: one well-built platform that covers every department, configured in weeks not months, at a price that makes sense for independent properties.</p>
            <p style="color: inherit;">From day one, we've been driven to cut through the complexity and give hoteliers something they rarely get from tech: momentum. Because when hoteliers have momentum, everything else follows: smoother days, stronger teams, and guests who can't wait to return.</p>
          </div>
          <div class="story-images">
            <div class="image-placeholder" style="aspect-ratio: 4/3; border-radius: 8px; overflow: hidden; background: transparent;">
              <img src="https://images.unsplash.com/photo-1581291518633-83b4ebd1d83e?auto=format&fit=crop&w=800&q=80" alt="Napkin wireframe sketch" style="width: 100%; height: 100%; object-fit: cover;" />
            </div>
          </div>
        </div>
      </div>

      <!-- Quick Facts -->
      <div class="quick-facts" style="margin-top: 64px;">
        <h3>Quick facts</h3>
        <div class="facts-grid">
          <div class="fact-item">
            <span class="fact-value">100</span>
            <span class="fact-label">Properties on HotelWise</span>
          </div>
          <div class="fact-item">
            <span class="fact-value">600</span>
            <span class="fact-label">Daily active users</span>
          </div>
          <div class="fact-item">
            <span class="fact-value">99.9%+</span>
            <span class="fact-label">Uptime SLA</span>
          </div>
          <div class="fact-item">
            <span class="fact-value">500</span>
            <span class="fact-label">Rooms managed daily</span>
          </div>
          <div class="fact-item">
            <span class="fact-value">98%</span>
            <span class="fact-label">Customer retention</span>
          </div>
          <div class="fact-item">
            <span class="fact-value">350</span>
            <span class="fact-label">Integrations supported</span>
          </div>
        </div>
      </div>
    </section>

    <div class="divider"></div>

    <!-- Built By People Who Care -->
    <section class="people-section container">
      <div class="people-header">
        <div>
          <div class="pill-badge" style="background: transparent; padding: 0; margin-bottom: 24px;">
            <span class="pill-icon" style="background: #9bd0ff;"></span> Our people
          </div>
          <h2>Built by people who've<br/>been there</h2>
        </div>
        <div class="people-intro">
          <p>We've run hotels, worked front desks, built software from scratch, and kept calm through the chaos that comes with it.</p>
          <p style="margin-top: 16px;">Today, we're a team of technologists, designers, engineers, and hoteliers, working together to untangle the mess that's been holding this industry back.</p>
        </div>
      </div>
      <div class="people-card">
        <div class="people-card-left">
          <div class="people-card-badge">
            <span style="display: inline-block; width: 12px; height: 12px; background: #1a1a1a; border-radius: 3px; margin-right: 8px;"></span> How we work
          </div>
          <h3 class="people-card-title">Installed locally, by design</h3>
          <div class="people-card-body">
            <p>HotelWise installs directly onto your own hardware. Your data never leaves your property unless you say so, with no cloud dependency, no third-party servers, and no guesswork about who has access.</p>
            <p>It means complete control over privacy, uptime that doesn't depend on your internet, and the convenience of a system that's always right there when you need it.</p>
          </div>
        </div>
        <div class="people-card-right">
          <img src="https://images.unsplash.com/photo-1566665797739-1674de7a421a?auto=format&fit=crop&w=800&q=80" alt="Local team working" style="width: 100%; height: 100%; object-fit: cover;" />
        </div>
      </div>
    </section>

    <div class="divider"></div>

    <!-- Values -->
    <section class="values-section">
      <div class="values-banner">
        <div class="container values-inner">
          <div class="values-text">
            <h2>Leading with heart,<br/>building with purpose.</h2>
          </div>
          <div class="values-list">
            <div class="value-item">
              <h4>Clarity over complexity</h4>
              <p>If a feature needs a training manual, it's not finished.</p>
            </div>
            <div class="value-item">
              <h4>Ship what matters</h4>
              <p>Every sprint starts with "which property needs this most?"</p>
            </div>
            <div class="value-item">
              <h4>Local first, global ready</h4>
              <p>Built for East African hospitality, designed to scale anywhere.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="about-cta-section container">
      <div class="about-cta-card">
        <div class="cta-grid-bg"></div>
        <div class="cta-content">
          <h2>Let's move hospitality forward,<br/>together.</h2>
          <p>HotelWise partners with hoteliers who dare to do things differently. From first booking to full-scale growth, we're here every step of the way.</p>
          <a href="/demo" class="cta-dark-btn">Request a demo &nearr;</a>
        </div>
      </div>
    </section>

    <!-- Press & Resources -->
    <section class="press-section container">
      <div class="press-row">
        <h3>Press Inquiries</h3>
        <a href="mailto:press@hotelwise.co.ke">press@hotelwise.co.ke &rarr;</a>
      </div>
      <div class="press-row">
        <h3>HotelWise logos</h3>
        <a href="#">Download media kit &rarr;</a>
      </div>
      <div class="press-row">
        <h3>Brand Guidelines</h3>
        <a href="#">View guidelines &rarr;</a>
      </div>
      <div class="press-row">
        <h3>About HotelWise</h3>
        <p class="press-blurb">HotelWise is hotel software built around how a hotel actually runs. Serving properties across East Africa, it unifies everything from front desk to back office into one real-time system.</p>
      </div>
    </section>

  </main>
  <Footer />
</Layout>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  // Hero
  gsap.from(".hero-left", { y: 30, opacity: 0, duration: 0.8, ease: "power3.out" });
  gsap.from(".hero-image", { y: 30, opacity: 0, duration: 0.8, ease: "power3.out", delay: 0.15 });

  // Sections
  const sections = [".mission-section", ".story-section", ".people-section", ".values-section", ".about-cta", ".press-section"];
  sections.forEach(sel => {
    gsap.from(sel, {
      scrollTrigger: { trigger: sel, start: "top 85%" },
      y: 40, opacity: 0, duration: 0.8, ease: "power2.out"
    });
  });

  // Facts stagger
  gsap.from(".fact-item", {
    scrollTrigger: { trigger: ".facts-grid", start: "top 85%" },
    y: 20, opacity: 0, duration: 0.5, stagger: 0.06, ease: "power2.out"
  });
</script>

<style>
  .about-page {
    padding-bottom: 0;
  }

  .hero-wrapper {
    position: relative;
    width: 100%;
  }
  .hero-wrapper::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background-size: 80px 80px;
    background-position: center top;
    background-image: 
      linear-gradient(to right, rgba(0,0,0,0.035) 1px, transparent 1px),
      linear-gradient(to bottom, rgba(0,0,0,0.035) 1px, transparent 1px);
    mask-image: linear-gradient(to bottom, black 60%, transparent 100%);
    -webkit-mask-image: linear-gradient(to bottom, black 60%, transparent 100%);
    z-index: -1;
    pointer-events: none;
  }
  .about-hero {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--spacing-xl);
    align-items: center;
    padding: 80px var(--spacing-lg) 64px;
  }
  .pill-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 0.9375rem;
    color: var(--text-primary);
    background: #ffffff;
    padding: 8px 16px;
    border-radius: 4px;
    margin-bottom: var(--spacing-lg);
    font-weight: 500;
  }
  .pill-icon {
    width: 14px;
    height: 14px;
    background: #9bd0ff;
    border-radius: 4px;
  }
  .about-hero h1 {
    font-size: 3.5rem;
    margin-bottom: var(--spacing-md);
    line-height: 1.15;
  }
  .hero-lead {
    font-size: 2rem;
    font-weight: 300;
    line-height: 1.35;
    color: var(--text-primary);
    margin: 0;
    font-family: var(--font-serif);
  }
  .hero-image {
    display: flex;
    justify-content: flex-end;
  }
  .image-placeholder {
    background: #f0ede6;
    border-radius: var(--radius-lg);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 2rem;
    color: rgba(0,0,0,0.15);
    width: 100%;
    aspect-ratio: 4 / 3;
  }
  .image-placeholder.tall {
    aspect-ratio: 3 / 4;
  }
  .image-placeholder.wide {
    aspect-ratio: 16 / 9;
  }

  .divider {
    max-width: 1200px;
    margin: 0 auto;
    height: 1px;
    background: rgba(0,0,0,0.06);
  }

  /* ── Mission ── */
  .mission-section {
    padding: 100px 0;
    background-color: #BFDEFF;
  }
  .mission-content {
    max-width: 720px;
  }
  .mission-heading {
    font-size: 2.75rem;
    font-weight: 600;
    margin-bottom: var(--spacing-lg);
    line-height: 1.15;
  }
  .mission-body {
    font-size: 1.0625rem;
    color: var(--text-secondary);
    line-height: 1.7;
    margin-bottom: var(--spacing-sm);
  }

  /* ── Story ── */
  .story-section {
    padding: 80px var(--spacing-lg);
  }
  .story-heading {
    font-size: 2.75rem;
    font-weight: 600;
    margin-bottom: 48px;
    line-height: 1.2;
  }
  .story-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--spacing-xl);
    margin-bottom: 64px;
  }
  .story-text p {
    font-size: 1.0625rem;
    color: var(--text-secondary);
    line-height: 1.7;
  }

  /* Quick Facts */
  .quick-facts h3 {
    font-size: 1.75rem;
    margin-bottom: var(--spacing-lg);
    color: var(--text-primary);
  }
  .facts-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: rgba(0,0,0,0.06);
    border: 1px solid rgba(0,0,0,0.06);
    border-radius: var(--radius-sm);
    overflow: hidden;
  }
  .fact-item {
    background: var(--bg-primary);
    padding: 32px 24px;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .fact-value {
    font-size: 2.5rem;
    font-weight: 600;
    color: var(--text-primary);
    line-height: 1;
    letter-spacing: -0.02em;
  }
  .fact-label {
    font-size: 0.8125rem;
    color: var(--text-tertiary);
  }

  /* ── People ── */
  .people-section {
    padding: 80px var(--spacing-lg);
  }
  .people-header {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--spacing-xl);
    margin-bottom: 48px;
    align-items: start;
  }
  .people-header h2 {
    font-size: 2.5rem;
    font-weight: 400;
    line-height: 1.2;
    margin: 0;
  }
  .people-intro p {
    font-size: 1.0625rem;
    color: var(--text-secondary);
    line-height: 1.7;
    margin: 0;
  }
  .people-card {
    display: grid;
    grid-template-columns: 1fr 1fr;
    border-radius: 8px;
    overflow: hidden;
    min-height: 420px;
  }
  .people-card-left {
    background: #BFDEFF;
    padding: 40px;
    display: flex;
    flex-direction: column;
  }
  .people-card-badge {
    display: inline-flex;
    align-items: center;
    font-size: 0.875rem;
    font-weight: 500;
    color: #1a1a1a;
    margin-bottom: 16px;
  }
  .people-card-title {
    font-size: 1.25rem;
    font-weight: 400;
    color: #1a1a1a;
    margin: 0 0 auto 0;
  }
  .people-card-body {
    margin-top: auto;
  }
  .people-card-body p {
    font-size: 0.9375rem;
    color: #1a1a1a;
    line-height: 1.65;
    margin: 0 0 12px 0;
  }
  .people-card-body p:last-child {
    margin-bottom: 0;
  }
  .people-card-right {
    overflow: hidden;
  }
  .people-card-right img {
    display: block;
  }



  /* ── Values ── */
  .values-section {
    padding: 0;
  }
  .values-banner {
    background: linear-gradient(135deg, #0a3d2f, #1a5632, #2d6b3f);
    color: white;
    padding: 80px 0;
  }
  .values-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--spacing-xl);
    align-items: start;
  }
  .values-text h2 {
    font-size: 2.5rem;
    font-weight: 300;
    line-height: 1.25;
    margin: 0;
  }
  .values-list {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-lg);
  }
  .value-item h4 {
    font-size: 1.125rem;
    margin-bottom: 6px;
    font-weight: 600;
  }
  .value-item p {
    font-size: 0.9375rem;
    color: rgba(255,255,255,0.7);
    margin: 0;
    line-height: 1.5;
  }

  /* ── CTA ── */
  .about-cta-section {
    padding: 80px var(--spacing-lg);
  }
  .about-cta-card {
    position: relative;
    background: #fcf18d; /* Vibrant pale yellow from reference */
    text-align: center;
    border-radius: var(--radius-sm);
    overflow: hidden;
    padding: 100px 40px;
    margin: 0 auto;
    max-width: 1000px;
  }
  .cta-grid-bg {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background-size: 80px 80px;
    background-position: center;
    background-image: 
      linear-gradient(to right, rgba(0,0,0,0.05) 1px, transparent 1px),
      linear-gradient(to bottom, rgba(0,0,0,0.05) 1px, transparent 1px);
    z-index: 1;
  }
  .cta-content {
    position: relative;
    z-index: 2;
    max-width: 650px;
    margin: 0 auto;
  }
  .cta-content h2 {
    font-size: 2.75rem;
    font-weight: 400;
    margin-bottom: var(--spacing-md);
    line-height: 1.25;
    color: var(--text-primary);
    letter-spacing: -0.02em;
  }
  .cta-content p {
    font-size: 1.0625rem;
    color: rgba(0,0,0,0.7);
    margin-bottom: 32px;
    line-height: 1.6;
    padding: 0 40px;
  }
  .cta-dark-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 14px 28px;
    border-radius: 4px;
    font-size: 0.9375rem;
    font-weight: 500;
    text-decoration: none;
    background: #1a1a1a;
    color: #ffffff;
    transition: background 0.2s, opacity 0.2s;
  }
  .cta-dark-btn:hover {
    opacity: 0.85;
  }

  /* ── Press ── */
  .press-section {
    padding: 80px var(--spacing-lg);
  }
  .press-row {
    display: grid;
    grid-template-columns: 250px 1fr;
    gap: var(--spacing-xl);
    align-items: baseline;
    padding: 24px 0;
    border-bottom: 1px solid rgba(0,0,0,0.06);
  }
  .press-row:first-child {
    border-top: 1px solid rgba(0,0,0,0.06);
  }
  .press-row h3 {
    font-size: 1.125rem;
    font-weight: 600;
    margin: 0;
  }
  .press-row a {
    font-size: 0.9375rem;
    color: var(--text-secondary);
    transition: color 0.2s;
  }
  .press-row a:hover {
    color: var(--text-primary);
  }
  .press-blurb {
    font-size: 0.875rem;
    color: var(--text-secondary);
    line-height: 1.7;
    margin: 0;
    max-width: 600px;
  }

  /* ── Responsive ── */
  @media (max-width: 768px) {
    .about-hero {
      grid-template-columns: 1fr;
      padding: 48px var(--spacing-lg);
    }
    .about-hero h1 {
      font-size: 2.5rem;
    }
    .hero-lead {
      font-size: 1.5rem;
    }
    .story-grid {
      grid-template-columns: 1fr;
    }
    .facts-grid {
      grid-template-columns: repeat(2, 1fr);
    }
    .people-header, .backed-header, .values-inner {
      grid-template-columns: 1fr;
    }
    .people-card {
      grid-template-columns: 1fr;
    }
    .people-card-right {
      min-height: 280px;
    }
    .press-row {
      grid-template-columns: 1fr;
      gap: var(--spacing-sm);
    }
  }
</style>
